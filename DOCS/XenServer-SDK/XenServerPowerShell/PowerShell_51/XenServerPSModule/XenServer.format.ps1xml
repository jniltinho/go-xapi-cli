<Configuration>
    <ViewDefinitions>
        <View>
            <Name>Session</Name>
            <ViewSelectedBy>
                <TypeName>XenAPI.Session</TypeName>
            </ViewSelectedBy>
            <ListControl>
                <ListEntries>
                    <ListEntry>
                        <ListItems>
                            <ListItem>
                                <PropertyName>Url</PropertyName>
                                <Label>URL</Label>
                            </ListItem>
                            <ListItem>
                                <PropertyName>opaque_ref</PropertyName>
                                <Label>Reference</Label>
                            </ListItem>
                            <ListItem>
                                <PropertyName>APIVersionString</PropertyName>
                                <Label>API Version</Label>
                            </ListItem>
                        </ListItems>
                    </ListEntry>
                </ListEntries>
            </ListControl>
        </View>        
    </ViewDefinitions>
</Configuration>

